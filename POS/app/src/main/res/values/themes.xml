<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.POS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Force Light Mode baseline for this specific theme as requested -->
        
        <!-- Primary Brand (Orange) -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        
        <!-- Status bar (Orange) -->
        <item name="android:statusBarColor">@color/brand_blue</item>
        
        <!-- Backgrounds -->
        <!-- Main background: Light Gray -->
        <item name="android:windowBackground">@color/bg_color</item>
        
        <!-- Cards and elevated surfaces: Silver -->
        <item name="colorSurface">@color/divider_color</item>
        <item name="colorOnSurface">@color/text_primary</item> <!-- Black text on Silver cards -->
        
        <!-- Text Colors globally forced to Black -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="PinKeypadStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SettingsButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/menu_button_bg</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Calculator Button Styles (Manual Entry Page etc.) -->
    <style name="CalcNumBtn" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item> <!-- Black numbers -->
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="strokeColor">@color/text_primary</item> <!-- Black borders -->
        <item name="cornerRadius">12dp</item>
        <item name="android:backgroundTint">@color/divider_color</item> <!-- Silver calc buttons -->
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CalcOpBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_on_brand</item> <!-- Light gray text -->
        <item name="android:backgroundTint">@color/brand_blue</item> <!-- Orange ops -->
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CalcClearBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:backgroundTint">@color/text_primary</item> <!-- Black clear button -->
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CalcEqualBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:backgroundTint">@color/brand_blue</item> <!-- Orange equal -->
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>