<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btnSettingsBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="SETTINGS"
        android:textColor="@color/brand_blue"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="@id/btnSettingsBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnSettingsBack" />

    <!-- 2x3 Grid of Settings Buttons -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:alignmentMode="alignBounds"
        android:columnCount="2"
        android:rowCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSettingsBack">

        <!-- Network -->
        <LinearLayout
            android:id="@+id/btnNetwork"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_network"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Network"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Display -->
        <LinearLayout
            android:id="@+id/btnDisplay"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_display"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Display"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- System -->
        <LinearLayout
            android:id="@+id/btnSystem"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_system"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="System"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Security -->
        <LinearLayout
            android:id="@+id/btnSecurity"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_security"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Security"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Sale Opts -->
        <LinearLayout
            android:id="@+id/btnSaleOpts"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_sale_opts"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sale Opts"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- About -->
        <LinearLayout
            android:id="@+id/btnAbout"
            style="@style/SettingsButtonStyle"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_about"
                app:tint="@color/brand_blue" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="About"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
